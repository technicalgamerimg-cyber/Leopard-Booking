// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeopardEnvironment {
  staging
  production
}

enum ShipmentStatus {
  PENDING
  BOOKED
  IN_TRANSIT
  DELIVERED
  RETURNED
  CANCELLED
  EXCEPTION
}

enum LoadsheetStatus {
  generated
  downloaded
}

enum WebhookStatus {
  received
  processed
  failed
  dead_letter
}

// Expanded to cover all observable events across the booking lifecycle.
enum ShipmentEvent {
  BOOKED
  BOOKING_FAILED
  CANCELLED
  STATUS_CHANGE
  ERROR
  LEOPARD_BOOKED
  LEOPARD_CANCELLED
  SHOPIFY_FULFILLMENT_CREATED
  SHOPIFY_FULFILLMENT_CANCELLED
  WEBHOOK_RECEIVED
  MANUAL_BOOK_ANYWAY
  PENDING_CANCELLATION_SET
  PENDING_CANCELLATION_EXECUTED
  SYNC_RETRY
  SYNC_FIXED
  SYNC_FAILED_PERMANENTLY
}

// Shopify writeback failures — two chains so Shopify and Leopards failures are never mixed.
enum ShopifySyncStatus {
  SYNC_OK
  FULFILLMENT_FAILED
  CANCEL_FAILED
  TRACKING_FAILED
  FAILED_PERMANENTLY
}

enum LeopardSyncStatus {
  SYNC_OK
  BOOKING_FAILED
  CANCEL_FAILED
  FAILED_PERMANENTLY
}

// Who created the active Shopify fulfillment for this order.
enum FulfillmentSource {
  OUR_APP
  SHOPIFY_ADMIN
  THIRD_PARTY
  UNKNOWN
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Store {
  id                  String    @id @default(cuid())
  shopDomain          String    @unique
  accessToken         String
  scopes              String?
  isActive            Boolean   @default(true)
  installedAt         DateTime  @default(now())
  uninstalledAt       DateTime?
  lastOrderSyncCursor String?   // GraphQL cursor for resumable order sync
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  settings    Settings?
  shipments   Shipment[]
  loadsheets  Loadsheet[]
  webhookLogs WebhookLog[]
  apiLogs     ApiLog[]
  cities      CityCache[]
}

model Settings {
  id                          String             @id @default(cuid())
  storeId                     String             @unique
  store                       Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  leopardApiKey               String?
  leopardApiPassword          String?
  leopardEnvironment          LeopardEnvironment @default(production)
  originCityId                Int?
  shipperName                 String?
  shipperPhone                String?
  shipperEmail                String?
  shipperAddress              String?
  defaultShipmentId           Int                @default(1)
  defaultWeightGrams          Int                @default(1000)
  defaultSpecialInstructions  String?
  fulfillmentWritebackEnabled Boolean            @default(true)
  codGatewayKeywords          String?
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
}

model Shipment {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // Version for optimistic concurrency — every write must increment this.
  version Int @default(1)

  // ── Shopify-sourced ───────────────────────────────────────────────────────
  // Mirror of Shopify order data. Updated by webhooks only.
  // financialStatus and totalPrice must never be used to change codAmount post-booking.
  shopifyOrderId   String
  shopifyOrderName String
  shopifyCreatedAt DateTime @default(now())
  financialStatus  String   @default("PENDING")
  totalPrice       Int      @default(0)        // raw order total in smallest currency unit; COD pre-fill source
  note             String?
  lineItemsCount   Int      @default(1)
  shopifyDeletedAt DateTime?                   // soft-delete only; never hard-delete

  // ── Consignee / logistics ─────────────────────────────────────────────────
  consigneeName    String
  consigneePhone   String
  consigneeAddress String

  // ── Booking state (owned by our DB) ──────────────────────────────────────
  status    ShipmentStatus @default(PENDING)
  codAmount Int            @default(0)  // LOCKED at booking; never updated post-booking
  weightGrams   Int        @default(1000)
  noOfPieces    Int        @default(1)
  originCityId  Int?
  destinationCityId Int?
  bookedAt    DateTime?
  cancelledAt DateTime?
  deliveredAt DateTime?
  lastError   String?

  // Set by cancel webhook when bookingLockedAt is active; booking service checks this post-commit.
  pendingCancellation Boolean @default(false)

  // Set when Shopify fulfillment is removed externally while a live CN exists.
  // Requires explicit merchant action — NOT auto-resolved.
  shopifySyncBroken Boolean @default(false)

  // ── Booking lock (true mutex) ─────────────────────────────────────────────
  // Only the process that set bookingLockId may release the lock.
  bookingLockedAt DateTime?
  bookingLockId   String?

  // ── Shopify sync status ───────────────────────────────────────────────────
  shopifySyncStatus ShopifySyncStatus @default(SYNC_OK)
  shopifyRetryCount Int               @default(0)
  shopifyRetryAfter DateTime?
  ourFulfillmentId  String?           // Shopify fulfillment GID created by our app

  // ── Leopards sync status ──────────────────────────────────────────────────
  leopardSyncStatus LeopardSyncStatus @default(SYNC_OK)
  leopardRetryCount Int               @default(0)
  leopardRetryAfter DateTime?

  // ── Leopards fields ───────────────────────────────────────────────────────
  // Set from Leopards API response. Never overwritten once populated.
  cnNumber            String?
  slipLink            String?
  bookedPacketOrderId String?
  leopardStatusRaw    String?

  // ── External fulfillment audit ────────────────────────────────────────────
  // Never cleared — permanent audit trail even after "Book Anyway" or cancellation.
  externalFulfillmentSource     FulfillmentSource?
  externalFulfillmentId         String?
  externalTrackingNumber        String?
  externalFulfillmentDetectedAt DateTime?

  logs       ShipmentLog[]
  loadsheets LoadsheetShipment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, shopifyOrderId])
  @@unique([storeId, cnNumber])
  @@index([storeId, status])
  @@index([storeId, bookedAt])
  @@index([storeId, shopifyDeletedAt])
  @@index([shopifySyncStatus])
  @@index([leopardSyncStatus])
  @@index([shopifyRetryAfter])
  @@index([leopardRetryAfter])
}

model Loadsheet {
  id          String              @id @default(cuid())
  storeId     String
  store       Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  loadSheetId String
  courierName String?
  courierCode String?
  cnCount     Int                 @default(0)
  status      LoadsheetStatus     @default(generated)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  shipments   LoadsheetShipment[]

  @@unique([storeId, loadSheetId])
  @@index([storeId])
}

model LoadsheetShipment {
  id          String    @id @default(cuid())
  loadsheetId String
  shipmentId  String
  loadsheet   Loadsheet @relation(fields: [loadsheetId], references: [id], onDelete: Cascade)
  shipment    Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([loadsheetId, shipmentId])
}

model ShipmentLog {
  id         String        @id @default(cuid())
  shipmentId String
  shipment   Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  eventType  ShipmentEvent
  fromStatus String?
  toStatus   String?
  message    String?
  createdAt  DateTime      @default(now())

  @@index([shipmentId])
  @@index([createdAt])
}

model WebhookLog {
  id               String        @id @default(cuid())
  storeId          String?
  store            Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  topic            String
  hmacValid        Boolean
  payloadDigest    String
  processingStatus WebhookStatus @default(received)
  error            String?
  createdAt        DateTime      @default(now())

  @@index([topic, payloadDigest])
  @@index([createdAt])
}

model ApiLog {
  id            String   @id @default(cuid())
  storeId       String?
  store         Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  endpoint      String
  httpStatus    Int?
  leopardStatus Int?
  latencyMs     Int
  retryCount    Int      @default(0)
  success       Boolean
  error         String?
  createdAt     DateTime @default(now())

  @@index([storeId])
  @@index([createdAt])
}

model CityCache {
  id                 String   @id @default(cuid())
  storeId            String
  store              Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  leopardCityId      Int
  name               String
  nameNormalized     String
  allowAsOrigin      Boolean  @default(true)
  allowAsDestination Boolean  @default(true)
  refreshedAt        DateTime @default(now())

  @@index([storeId, nameNormalized])
  @@unique([storeId, leopardCityId])
}
