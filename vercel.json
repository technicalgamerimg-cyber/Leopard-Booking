{
  "version": 2,
  "buildCommand": "npm run setup && npm run build",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/server.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/server" }
  ]
}
