{
  "version": 2,
  "buildCommand": "npm run setup && npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "build/server/index.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/build/client/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/build/server/index.js"
    }
  ]
}
